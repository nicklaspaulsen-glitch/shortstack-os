{
  "manifest_version": 3,
  "name": "ShortStack OS — Quick Actions",
  "description": "Add leads, create posts, and take actions from any webpage",
  "version": "1.0.0",
  "permissions": ["activeTab", "storage", "contextMenus", "notifications", "alarms", "tabs"],
  "host_permissions": ["https://app.shortstack.work/*", "https://*.shortstack.app/*"],
  "externally_connectable": {
    "matches": ["https://app.shortstack.work/*", "https://*.shortstack.app/*"]
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["api.js", "content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
