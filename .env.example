# ============================================
# ShortStack OS — Production Environment Variables
# Copy this to .env.local and fill in all values
# ============================================

# ── Core Infrastructure ──────────────────────────
NEXT_PUBLIC_APP_URL="https://your-domain.com"
NEXT_PUBLIC_SUPABASE_URL="https://xxxxx.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-supabase-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"

# ── AI / LLM ────────────────────────────────────
ANTHROPIC_API_KEY="sk-ant-api03-xxx"
OPENAI_API_KEY=""  # Optional — fallback for some agent generation

# ── Stripe Billing ──────────────────────────────
STRIPE_SECRET_KEY="sk_live_xxx"
STRIPE_WEBHOOK_SECRET="whsec_xxx"            # Main webhook signing secret
STRIPE_BILLING_WEBHOOK_SECRET=""              # Optional override for billing webhook

# Stripe Price IDs — create these in Stripe Dashboard > Products
# Monthly plans
STRIPE_PRICE_STARTER=""
STRIPE_PRICE_GROWTH=""
STRIPE_PRICE_PRO=""
STRIPE_PRICE_BUSINESS=""
STRIPE_PRICE_UNLIMITED=""
# Annual plans (20% discount applied in checkout if not set)
STRIPE_PRICE_STARTER_ANNUAL=""
STRIPE_PRICE_GROWTH_ANNUAL=""
STRIPE_PRICE_PRO_ANNUAL=""
STRIPE_PRICE_BUSINESS_ANNUAL=""
STRIPE_PRICE_UNLIMITED_ANNUAL=""

# ── RunPod GPU Endpoints ────────────────────────
RUNPOD_API_KEY="rpa_xxx"
RUNPOD_LLM_URL="https://api.runpod.ai/v2/xxx"
RUNPOD_SDXL_URL="https://api.runpod.ai/v2/xxx"
RUNPOD_FLUX_URL="https://api.runpod.ai/v2/xxx"
HIGGSFIELD_URL="https://api.runpod.ai/v2/xxx"
# New GPU features — deploy workers then add URLs
RUNPOD_WHISPER_URL="https://api.runpod.ai/v2/xxx"
RUNPOD_UPSCALE_URL="https://api.runpod.ai/v2/xxx"
RUNPOD_REMBG_URL="https://api.runpod.ai/v2/xxx"
RUNPOD_SVD_URL="https://api.runpod.ai/v2/xxx"
RUNPOD_MUSICGEN_URL="https://api.runpod.ai/v2/xxx"
RUNPOD_XTTS_URL="https://api.runpod.ai/v2/xxx"
RUNPOD_LORA_URL="https://api.runpod.ai/v2/xxx"

# ── Telegram Notifications ──────────────────────
TELEGRAM_BOT_TOKEN="xxx:yyy"
TELEGRAM_CHAT_ID="your-chat-id"
TELEGRAM_WEBHOOK_SECRET="random-secret-string"

# ── Cron & Webhooks ─────────────────────────────
CRON_SECRET="random-secret-for-cron-endpoints"
WEBHOOK_SECRET="random-secret-for-inbound-webhooks"

