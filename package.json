{
  "name": "shortstack-os",
  "version": "1.2.0",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "electron": "electron .",
    "electron:build": "electron-builder --win",
    "desktop": "electron ."
  },
  "build": {
    "appId": "com.shortstack.os",
    "productName": "ShortStack OS",
    "copyright": "Copyright 2026 ShortStack",
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "public/icons/shortstack-logo.ico",
      "artifactName": "ShortStack-OS-${version}-Setup.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "installerIcon": "public/icons/shortstack-logo.ico",
      "uninstallerIcon": "public/icons/shortstack-logo.ico",
      "installerHeaderIcon": "public/icons/shortstack-logo.ico",
      "shortcutName": "ShortStack OS"
    },
    "portable": {
      "artifactName": "ShortStack-OS-${version}-Portable.${ext}"
    },
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "electron/**/*",
      "public/icons/**/*"
    ],
    "extraMetadata": {
      "main": "electron/main.js"
    }
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.82.0",
    "@stripe/stripe-js": "^9.0.1",
    "@supabase/auth-helpers-nextjs": "^0.15.0",
    "@supabase/ssr": "^0.10.0",
    "@supabase/supabase-js": "^2.101.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "lucide-react": "^1.7.0",
    "next": "14.2.35",
    "node-cron": "^4.2.1",
    "openai": "^6.33.0",
    "pdfkit": "^0.18.0",
    "playwright-core": "^1.59.1",
    "puppeteer-core": "^24.40.0",
    "react": "^18",
    "react-dom": "^18",
    "react-hot-toast": "^2.6.0",
    "react-icons": "^5.6.0",
    "recharts": "^3.8.1",
    "stripe": "^22.0.0",
    "tweetnacl": "^1.0.3",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/pdfkit": "^0.17.5",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@vitejs/plugin-react": "^6.0.1",
    "electron": "^41.1.1",
    "electron-builder": "^26.8.1",
    "eslint": "^8",
    "eslint-config-next": "14.2.35",
    "jsdom": "^29.0.2",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "typescript": "^5",
    "vitest": "^4.1.4"
  }
}
