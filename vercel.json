{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(self), geolocation=()" },
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" }
      ]
    }
  ],
  "crons": [
    {
      "path": "/api/cron/daily-brief",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/outreach",
      "schedule": "0 9 * * 1-5"
    },
    {
      "path": "/api/cron/health-check",
      "schedule": "*/30 * * * *"
    },
    {
      "path": "/api/cron/scrape-leads",
      "schedule": "0 5 * * *"
    },
    {
      "path": "/api/cron/content-autopilot",
      "schedule": "0 7 * * 1"
    },
    {
      "path": "/api/cron/retention-check",
      "schedule": "0 10 * * *"
    },
    {
      "path": "/api/cron/invoice-chase",
      "schedule": "0 11 * * *"
    },
    {
      "path": "/api/reports/client-weekly",
      "schedule": "0 15 * * 5"
    },
    {
      "path": "/api/cron/lead-cleanup",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/follow-up",
      "schedule": "0 14 * * 1-5"
    },
    {
      "path": "/api/cron/lead-scoring",
      "schedule": "0 4 * * *"
    },
    {
      "path": "/api/cron/reminders",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/token-refresh",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/weekly-digest",
      "schedule": "0 9 * * 1"
    },
    {
      "path": "/api/cron/review-monitor",
      "schedule": "0 */6 * * *"
    },
    {
      "path": "/api/cron/ads-autopilot",
      "schedule": "0 */4 * * *"
    },
    {
      "path": "/api/cron/social-autopilot",
      "schedule": "0 */2 * * *"
    },
    {
      "path": "/api/cron/budget-alert",
      "schedule": "0 */6 * * *"
    },
    {
      "path": "/api/cron/cleanup-senders",
      "schedule": "0 3 * * 0"
    },
    {
      "path": "/api/cron/process-deletions",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/cron/publish-scheduled",
      "schedule": "*/15 * * * *"
